{
  "name": "custom-api",
  "description": "Please enter a description for your extension",
  "icon": "extension",
  "version": "1.0.0",
  "keywords": [
    "directus",
    "directus-extension",
    "directus-extension-endpoint"
  ],
  "type": "module",
  "files": [
    "dist"
  ],
  "directus:extension": {
    "type": "endpoint",
    "path": "dist/index.js",
    "source": "src/index.ts",
    "host": "^10.10.0"
  },
  "scripts": {
    "build": "directus-extension build",
    "dev": "directus-extension build -w --no-minify",
    "link": "directus-extension link",
    "validate": "directus-extension validate",
    "sync": "npm run build && rm -rf ../extensions/endpoints/custom-api && mkdir -p ../extensions/endpoints/custom-api && cp -r dist package.json ../extensions/endpoints/custom-api/"
  },
  "devDependencies": {
    "@directus/extensions-sdk": "17.0.11",
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  }
}
